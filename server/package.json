  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.2.0",
    "cross-env": "^10.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3"
  }
